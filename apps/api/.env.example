# 复制为 .env 用于本地开发。

# 数据库连接串（建议使用只读角色）。
GAOKAO_DATABASE_URL=postgresql://gaokao:gaokao_dev_password@localhost:15432/gaokao

# LLM（OpenAI 兼容接口）。默认使用 DeepSeek V4 Flash。
# base_url 用 https://api.deepseek.com 即可（/v1 后缀也兼容）。
# model 默认 deepseek-v4-flash；如需更强推理可手动切换 deepseek-v4-pro。
GAOKAO_LLM_BASE_URL=https://api.deepseek.com
GAOKAO_LLM_API_KEY=
GAOKAO_LLM_MODEL=deepseek-v4-flash
GAOKAO_LLM_TEMPERATURE=0
GAOKAO_LLM_TIMEOUT=60
# 开启后，/query 会先用 LLM 抽取结构化意图，再由程序生成安全 SQL。
GAOKAO_LLM_INTENT_ENABLED=true

# SQL 查询答案生成。默认开启；未配置 LLM Key 时自动跳过。
GAOKAO_SQL_ANSWER_ENABLED=true
GAOKAO_SQL_ANSWER_MAX_ROWS=20
GAOKAO_SQL_ANSWER_MAX_CHARS=12000

# RAG 答案生成。默认关闭，只返回候选 chunk；开启后复用上面的 LLM 配置。
GAOKAO_RAG_ANSWER_ENABLED=false
GAOKAO_RAG_ANSWER_MAX_CONTEXT_CHARS=12000
GAOKAO_RAG_ANSWER_MAX_HITS=3

# Embedding。默认使用本地 sentence-transformers，需与 rag_chunk.embedding 的 2560 维一致。
GAOKAO_EMBEDDING_PROVIDER=local
GAOKAO_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
GAOKAO_EMBEDDING_DIMENSION=2560
GAOKAO_EMBEDDING_DEVICE=
GAOKAO_EMBEDDING_TORCH_DTYPE=auto
GAOKAO_EMBEDDING_CACHE_FOLDER=models
GAOKAO_EMBEDDING_NORMALIZE=true
GAOKAO_EMBEDDING_QUERY_INSTRUCTION_ENABLED=true

# 可选：当需要切回 OpenAI 兼容 Embedding API 时，设置 GAOKAO_EMBEDDING_PROVIDER=openai。
GAOKAO_EMBEDDING_BASE_URL=https://api-inference.modelscope.cn/v1
GAOKAO_EMBEDDING_API_KEY=
GAOKAO_EMBEDDING_ENCODING_FORMAT=float
GAOKAO_EMBEDDING_MAX_RETRIES=3

# 可选 API Key 鉴权。设置后 /query 需要请求头 X-API-Key。留空则不鉴权（仅本地开发）。
GAOKAO_API_KEY=

# 查询限制。
GAOKAO_DEFAULT_LIMIT=200
GAOKAO_MAX_LIMIT=1000
GAOKAO_POLICY_DEFAULT_TOP_K=5
GAOKAO_POLICY_MAX_TOP_K=20
GAOKAO_STATEMENT_TIMEOUT_MS=10000
