# 复制本文件为 .env 用于本地开发：cp .env.example .env
# 这是整个项目的统一配置入口（Docker 数据库 + NL2SQL API + LLM）。

# ===== Docker PostgreSQL =====
GAOKAO_POSTGRES_HOST_PORT=15432
GAOKAO_POSTGRES_IMAGE=pgvector/pgvector:pg16
GAOKAO_POSTGRES_DB=gaokao
GAOKAO_POSTGRES_USER=gaokao
GAOKAO_POSTGRES_PASSWORD=gaokao_dev_password
DATABASE_URL=postgresql://gaokao:gaokao_dev_password@localhost:15432/gaokao

# ===== NL2SQL API 数据库连接（建议使用只读角色）=====
GAOKAO_DATABASE_URL=postgresql://gaokao:gaokao_dev_password@localhost:15432/gaokao
GAOKAO_API_HOST_PORT=8000
GAOKAO_WEB_HOST_PORT=5173

# ===== LLM（OpenAI 兼容接口，默认 DeepSeek V4 Flash）=====
# >>> 在下面这行等号后面粘贴你的 DeepSeek API Key <<<
GAOKAO_LLM_API_KEY=
GAOKAO_LLM_BASE_URL=https://api.deepseek.com
GAOKAO_LLM_MODEL=deepseek-v4-flash
GAOKAO_LLM_TEMPERATURE=0
GAOKAO_LLM_TIMEOUT=60
# 开启后，/query 会先用 LLM 抽取结构化意图，再由程序生成安全 SQL。
GAOKAO_LLM_INTENT_ENABLED=true

# ===== ai-gpurent-cli LLM_TEXT_CHAT 代理（Web 端填 key 时启用）=====
# Docker Desktop/macOS 默认可通过 host.docker.internal 访问宿主机上的 ai-gpurent-cli server。
GAOKAO_AI_GPURENT_BASE_URL=https://api.cfyzswl.online
GAOKAO_AI_GPURENT_API_KEY=
GAOKAO_AI_GPURENT_PROVIDER=deepseek
GAOKAO_AI_GPURENT_TASK_TIMEOUT_SEC=300
GAOKAO_AI_GPURENT_POLL_TIMEOUT=300
GAOKAO_AI_GPURENT_POLL_INTERVAL=1
GAOKAO_AI_GPURENT_HTTP_TIMEOUT=15

# ===== SQL 查询答案生成（默认开启；未配置 LLM Key 时自动跳过）=====
GAOKAO_SQL_ANSWER_ENABLED=true
GAOKAO_SQL_ANSWER_MAX_ROWS=20
GAOKAO_SQL_ANSWER_MAX_CHARS=12000

# ===== RAG 答案生成（默认关闭；开启后复用上面的 LLM 配置）=====
GAOKAO_RAG_ANSWER_ENABLED=false
GAOKAO_RAG_ANSWER_MAX_CONTEXT_CHARS=12000
GAOKAO_RAG_ANSWER_MAX_HITS=3

# ===== Embedding（Docker 一键环境默认使用 OpenAI 兼容接口，避免启动时下载本地大模型）=====
GAOKAO_EMBEDDING_PROVIDER=openai
GAOKAO_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
GAOKAO_EMBEDDING_DIMENSION=2560
GAOKAO_EMBEDDING_DEVICE=auto
GAOKAO_EMBEDDING_TORCH_DTYPE=auto
GAOKAO_EMBEDDING_CACHE_FOLDER=models
GAOKAO_EMBEDDING_NORMALIZE=true
GAOKAO_EMBEDDING_QUERY_INSTRUCTION_ENABLED=true
GAOKAO_EMBEDDING_BASE_URL=https://api-inference.modelscope.cn/v1
GAOKAO_EMBEDDING_API_KEY=
GAOKAO_EMBEDDING_ENCODING_FORMAT=float
GAOKAO_EMBEDDING_MAX_RETRIES=3
# 可选：本地 Python 开发如需本地模型，可设置 GAOKAO_EMBEDDING_PROVIDER=local，
# 并安装 apps/api[local-embedding]。

# ===== API 服务 =====
GAOKAO_API_KEY=
GAOKAO_DEFAULT_LIMIT=200
GAOKAO_MAX_LIMIT=1000
GAOKAO_POLICY_DEFAULT_TOP_K=5
GAOKAO_POLICY_MAX_TOP_K=20
GAOKAO_STATEMENT_TIMEOUT_MS=10000
